# =============================================================================
# Memory Architecture — All 5 Memory Systems
# Render: d2 render memory-architecture.d2 memory-architecture.svg
# =============================================================================

direction: down

title: "Arcanea Memory Architecture" {
  shape: text
  style.font-size: 28
  style.bold: true
  style.font-color: "#78a6ff"
}

# ---------------------------------------------------------------------------
# System 1: Starlight Intelligence System (SIS) — 6 Vaults
# ---------------------------------------------------------------------------
sis: "System 1: Starlight Intelligence System\nPersistent Cross-Session Memory" {
  style.fill: "#0b0e14"
  style.stroke: "#ffd700"
  style.font-color: "#ffd700"
  style.border-radius: 8
  style.stroke-width: 2

  desc: "5-Layer Cognitive Architecture\nIntelligence is infrastructure" {
    shape: text
    style.font-size: 11
    style.font-color: "#c0c0c0"
  }

  vaults: "6 Persistent Vaults" {
    style.fill: "#1a1a2e"
    style.stroke: "#ffd700"
    style.font-color: "#ffd700"
    style.border-radius: 6

    strategic: "Strategic Vault\nArchitectural decisions\nProduct direction" {
      style.fill: "#252540"
      style.stroke: "#ffd700"
      style.font-color: "#e0e0e0"
    }
    technical: "Technical Vault\nPatterns, solutions\nStack knowledge" {
      style.fill: "#252540"
      style.stroke: "#78a6ff"
      style.font-color: "#e0e0e0"
    }
    creative: "Creative Vault\nVoice, style\nNarrative patterns" {
      style.fill: "#252540"
      style.stroke: "#9966ff"
      style.font-color: "#e0e0e0"
    }
    operational: "Operational Vault\nSession logs\nRecent context" {
      style.fill: "#252540"
      style.stroke: "#7fffd4"
      style.font-color: "#e0e0e0"
    }
    wisdom: "Wisdom Vault\nCross-domain insights\nMeta-patterns\nPermanent" {
      style.fill: "#252540"
      style.stroke: "#ffd700"
      style.font-color: "#ffd700"
    }
    horizon: "Horizon Vault\nHuman values + hopes\nAI alignment\nAppend-only" {
      style.fill: "#252540"
      style.stroke: "#ff6b35"
      style.font-color: "#ff6b35"
    }
  }

  ranking: "Vault Ranking Formula\nrelevance * 0.4 + recency * 0.3 + confidence * 0.3" {
    shape: text
    style.font-size: 10
    style.font-color: "#c0c0c0"
  }

  transmissions: "4 Transmission Channels" {
    style.fill: "#1a1a2e"
    style.stroke: "#78a6ff"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    acos-ch: "ACOS Channel\nBidirectional" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
    arcanea-ch: "Arcanea Channel\nBidirectional" {style.fill: "#252540"; style.stroke: "#7fffd4"; style.font-color: "#e0e0e0"}
    aiops-ch: "AI-Ops Channel\nBidirectional" {style.fill: "#252540"; style.stroke: "#9966ff"; style.font-color: "#e0e0e0"}
    broadcast: "Broadcast\nSIS to All" {style.fill: "#252540"; style.stroke: "#ffd700"; style.font-color: "#e0e0e0"}
  }
}

# ---------------------------------------------------------------------------
# System 2: AgentDB (AIOS State Protocol)
# ---------------------------------------------------------------------------
agentdb: "System 2: AgentDB — AIOS State Protocol\nSession-Level State + Guardian Context" {
  style.fill: "#0b0e14"
  style.stroke: "#7fffd4"
  style.font-color: "#7fffd4"
  style.border-radius: 8
  style.stroke-width: 2

  sqlite: "SQLite Database\n/tmp/arcanea-agentdb.sqlite3" {
    style.fill: "#1a1a2e"
    style.stroke: "#7fffd4"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    agents-table: "agents\n10 Guardians seeded" {style.fill: "#252540"; style.stroke: "#7fffd4"; style.font-color: "#e0e0e0"}
    memories-table: "memories\nSession memories" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
    tasks-table: "tasks\nTask lifecycle" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
    routing-table: "routing_log\nGuardian routing history" {style.fill: "#252540"; style.stroke: "#ffd700"; style.font-color: "#e0e0e0"}
    vault-table: "vault_entries\n6 initial vault entries" {style.fill: "#252540"; style.stroke: "#ffd700"; style.font-color: "#e0e0e0"}
    swarm-table: "swarm_sessions\nSwarm coordination" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
  }

  state-files: "State Protocol Files\n/tmp/arcanea-*" {
    style.fill: "#1a1a2e"
    style.stroke: "#7fffd4"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    guardian-file: "/tmp/arcanea-guardian\nActive Guardian name" {style.fill: "#252540"; style.stroke: "#7fffd4"; style.font-color: "#e0e0e0"}
    gate-file: "/tmp/arcanea-gate\nActive Gate" {style.fill: "#252540"; style.stroke: "#7fffd4"; style.font-color: "#e0e0e0"}
    element-file: "/tmp/arcanea-element\nActive Element" {style.fill: "#252540"; style.stroke: "#7fffd4"; style.font-color: "#e0e0e0"}
    model-file: "/tmp/arcanea-model-recommendation\nModel tier" {style.fill: "#252540"; style.stroke: "#ffd700"; style.font-color: "#e0e0e0"}
    context-file: "/tmp/arcanea-context-status\nToken budget" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
  }
}

# ---------------------------------------------------------------------------
# System 3: MCP Vault Tools (arcanea-memory)
# ---------------------------------------------------------------------------
mcp-vault: "System 3: MCP Vault Tools\narcanea-memory MCP Server" {
  style.fill: "#0b0e14"
  style.stroke: "#9966ff"
  style.font-color: "#9966ff"
  style.border-radius: 8
  style.stroke-width: 2

  tools: "Vault Operations" {
    style.fill: "#1a1a2e"
    style.stroke: "#9966ff"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    remember: "vault_remember\nStore new memory" {style.fill: "#252540"; style.stroke: "#9966ff"; style.font-color: "#e0e0e0"}
    recall: "vault_recall\nSearch by query" {style.fill: "#252540"; style.stroke: "#9966ff"; style.font-color: "#e0e0e0"}
    classify: "vault_classify\nAuto-categorize" {style.fill: "#252540"; style.stroke: "#9966ff"; style.font-color: "#e0e0e0"}
    recent: "vault_recent\nRecent entries" {style.fill: "#252540"; style.stroke: "#9966ff"; style.font-color: "#e0e0e0"}
    stats: "vault_stats\nMemory statistics" {style.fill: "#252540"; style.stroke: "#9966ff"; style.font-color: "#e0e0e0"}
    sync: "memory_sync\nCross-system sync" {style.fill: "#252540"; style.stroke: "#ffd700"; style.font-color: "#e0e0e0"}
  }

  horizon-tools: "Horizon Vault" {
    style.fill: "#1a1a2e"
    style.stroke: "#ff6b35"
    style.font-color: "#ff6b35"
    style.border-radius: 6

    append: "horizon_append\nAppend-only" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
    read: "horizon_read\nRead entries" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
  }
}

# ---------------------------------------------------------------------------
# System 4: Creative Session Memory
# ---------------------------------------------------------------------------
creative-session: "System 4: Creative Session Memory\nPlatform-Level User State" {
  style.fill: "#0b0e14"
  style.stroke: "#ff6b35"
  style.font-color: "#ff6b35"
  style.border-radius: 8
  style.stroke-width: 2

  supabase: "Supabase (PostgreSQL)" {
    style.fill: "#1a1a2e"
    style.stroke: "#3ecf8e"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    user-state: "User Profiles\nGate progress\nCreation history" {style.fill: "#252540"; style.stroke: "#3ecf8e"; style.font-color: "#e0e0e0"}
    chat-history: "Chat Sessions\nAI conversation logs\nContext windows" {style.fill: "#252540"; style.stroke: "#3ecf8e"; style.font-color: "#e0e0e0"}
    creations: "User Creations\nWorlds, characters\nStories, art" {style.fill: "#252540"; style.stroke: "#3ecf8e"; style.font-color: "#e0e0e0"}
    feed: "Feed Data\nShared content\nSocial interactions" {style.fill: "#252540"; style.stroke: "#3ecf8e"; style.font-color: "#e0e0e0"}
  }

  realtime: "Supabase Realtime\nLive session state\nCollaborative editing" {
    style.fill: "#1a1a2e"
    style.stroke: "#3ecf8e"
    style.font-color: "#e0e0e0"
    style.border-radius: 6
  }
}

# ---------------------------------------------------------------------------
# System 5: Claude Flow Hooks Memory
# ---------------------------------------------------------------------------
claude-flow: "System 5: Claude Flow Hooks\nSwarm + Agent Memory" {
  style.fill: "#0b0e14"
  style.stroke: "#78a6ff"
  style.font-color: "#78a6ff"
  style.border-radius: 8
  style.stroke-width: 2

  memory-commands: "Claude Flow Memory CLI" {
    style.fill: "#1a1a2e"
    style.stroke: "#78a6ff"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    store: "memory store\n--key --value --namespace" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
    search: "memory search\n--query (HNSW vector)" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
    retrieve: "memory retrieve\nBy key + namespace" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
    list: "memory list\nFiltered by namespace" {style.fill: "#252540"; style.stroke: "#78a6ff"; style.font-color: "#e0e0e0"}
  }

  hooks-memory: "Hook-Driven State" {
    style.fill: "#1a1a2e"
    style.stroke: "#ff6b35"
    style.font-color: "#e0e0e0"
    style.border-radius: 6

    session-start: "session-start hook\nInit state + AgentDB" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
    context-tracker: "context-tracker hook\nToken budget tracking" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
    post-task: "post-task hook\nSwarm checkpoints" {style.fill: "#252540"; style.stroke: "#ff6b35"; style.font-color: "#e0e0e0"}
  }

  vectors: "vectors.db\nHNSW Index\nNeural search" {
    style.fill: "#1a1a2e"
    style.stroke: "#ffd700"
    style.font-color: "#ffd700"
    style.border-radius: 6
  }
}

# ---------------------------------------------------------------------------
# Connections Between Systems
# ---------------------------------------------------------------------------

# SIS <-> AgentDB
sis.vaults -> agentdb.sqlite: "vault entries\nseeded on init" {
  style.stroke: "#ffd700"
  style.stroke-width: 2
}
agentdb.sqlite -> sis.vaults: "session learnings\nflow upward" {
  style.stroke: "#ffd700"
  style.stroke-dash: 3
}

# SIS <-> MCP Vault
sis.vaults -> mcp-vault.tools: "vault operations\nvia MCP protocol" {
  style.stroke: "#9966ff"
  style.stroke-width: 2
}
sis.vaults.horizon -> mcp-vault.horizon-tools: "append-only\nhuman values" {
  style.stroke: "#ff6b35"
}

# AgentDB <-> Claude Flow
agentdb.state-files -> claude-flow.hooks-memory: "state protocol\n/tmp/arcanea-*" {
  style.stroke: "#7fffd4"
  style.stroke-width: 2
}
claude-flow.memory-commands -> agentdb.sqlite: "agent memory\npersistence" {
  style.stroke: "#78a6ff"
  style.stroke-dash: 3
}

# MCP Vault <-> Creative Session
mcp-vault.tools.sync -> creative-session.supabase: "memory sync\nto platform DB" {
  style.stroke: "#3ecf8e"
  style.stroke-dash: 3
}

# Claude Flow <-> SIS
claude-flow.vectors -> sis.vaults: "HNSW vector search\ncompound learning" {
  style.stroke: "#ffd700"
  style.stroke-dash: 5
}

# Creative Session <-> SIS
creative-session.supabase -> sis.transmissions.arcanea-ch: "creative patterns\nuser insights" {
  style.stroke: "#7fffd4"
  style.stroke-dash: 5
}

# ---------------------------------------------------------------------------
# Data Flow Legend
# ---------------------------------------------------------------------------
legend: "Legend" {
  style.fill: "#0b0e14"
  style.stroke: "#e0e0e0"
  style.font-color: "#e0e0e0"
  style.border-radius: 6

  l1: "Solid line = direct data flow" {shape: text; style.font-size: 10; style.font-color: "#e0e0e0"}
  l2: "Dashed line = async / periodic sync" {shape: text; style.font-size: 10; style.font-color: "#c0c0c0"}
  l3: "Gold = intelligence layer (SIS)" {shape: text; style.font-size: 10; style.font-color: "#ffd700"}
  l4: "Teal = state protocol (AIOS)" {shape: text; style.font-size: 10; style.font-color: "#7fffd4"}
  l5: "Purple = MCP operations" {shape: text; style.font-size: 10; style.font-color: "#9966ff"}
  l6: "Blue = claude-flow swarm" {shape: text; style.font-size: 10; style.font-color: "#78a6ff"}
}
