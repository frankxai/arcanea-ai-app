{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Arcanea Plugin Configuration",
  "description": "Schema for Arcanea Claude Code plugin manifest",
  "type": "object",
  "required": ["name", "version"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Plugin identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic version"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directory paths to command definitions"
    },
    "skills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directory paths to skill definitions"
    },
    "agents": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit file paths to agent definitions"
    },
    "rules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Directory paths to rule files"
    },
    "features": {
      "type": "object",
      "properties": {
        "agents": { "type": "integer" },
        "commands": { "type": "integer" },
        "skills": { "type": "integer" },
        "rules": { "type": "integer" },
        "configAssets": { "type": "boolean" },
        "hookEvents": {
          "type": "array",
          "items": { "type": "string" }
        },
        "customTools": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "config": {
      "type": "object",
      "description": "Plugin-specific configuration"
    }
  }
}
