{
  "name": "@arcanea/world-engine",
  "version": "0.2.0",
  "description": "Pure worldbuilding logic shared between the Arcanea MCP server and web app",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "arcanea",
    "worldbuilding",
    "fantasy",
    "generators"
  ],
  "author": "FrankX",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
