{
  "compilerOptions": {
    "target":          "ES2022",
    "module":          "ESNext",
    "moduleResolution":"bundler",
    "outDir":          "./dist",
    "rootDir":         "./src",
    "strict":          true,
    "declaration":     true,
    "declarationMap":  true,
    "sourceMap":       true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
