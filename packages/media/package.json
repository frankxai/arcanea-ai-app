{
  "name": "@arcanea/media",
  "version": "0.1.0",
  "description": "Arcanea Media Intelligence — local-first media management, processing and catalog for the Arcanea universe",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "arcanea-media": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev":   "tsc --watch",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist"
  },
  "keywords": ["arcanea", "media", "images", "video", "guardian", "catalog"],
  "author": "FrankX",
  "license": "MIT",
  "dependencies": {
    "sharp":          "^0.33.0",
    "chokidar":       "^3.6.0",
    "fluent-ffmpeg":  "^2.1.3",
    "glob":           "^11.0.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node":          "^20.10.0",
    "typescript":           "^5.3.0"
  },
  "engines": { "node": ">=18.0.0" }
}
