# Arcanea Publishing House — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
# Claude / Anthropic API key (required for all tiers)
ANTHROPIC_API_KEY=

# ── Cloud tier (optional — free tier works without these) ─────────────────────
# Supabase project URL and service-role key
SUPABASE_URL=
SUPABASE_KEY=

# Notion integration token (for Editorial Board databases)
NOTION_TOKEN=

# ── AI providers (optional — enables multi-model routing) ─────────────────────
# Google Gemini API key (alternative model for translation/drafting)
GEMINI_API_KEY=

# ── Distribution connectors (optional — per-platform) ────────────────────────
# Leanpub API key (for automated book publishing)
LEANPUB_API_KEY=

# DeepL API key (for professional translation, free tier uses Claude)
DEEPL_API_KEY=

# ── Billing (optional — free tier works without Stripe) ──────────────────────
# Stripe secret key (enables Pro/Fleet/Enterprise tier detection)
STRIPE_API_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Server port (default: 8080)
PORT=8080

# Node environment
NODE_ENV=production
