{
  "name": "@arcanea/vault-cli",
  "version": "1.0.0",
  "description": "Local system of record for processing exported AI conversations",
  "type": "module",
  "bin": {
    "arcanea-vault": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "node --test dist/**/*.test.js",
