{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(bash .claude/*:*)",
      "Bash(cat:*)",
      "Bash(where:*)",
      "Bash(ls -d .claude/skills/*/)",
      "Bash(ls -d .claude/commands/*/)",
      "Bash(find .claude/skills -name *.md -exec wc -l {})",
      "Bash(2)",
      "Bash(echo \"EXIT:$?\")",
      "Bash(pnpm --dir apps/web build,)",
      "Bash(pnpm --dir apps/web build)",
      "Bash(echo EXIT:$?)",
      "Bash(echo \"TSC:$?\")",
      "Bash(echo \"CHAT_IMAGINE:$?\")"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "next-devtools",
    "github",
    "supabase",
    "arcanea-mcp",
    "arcanea-memory",
    "figma-remote-mcp",
    "notion",
    "linear-server",
    "playwright"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/prompt-submit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node .claude/statusline.mjs"
  }
}
