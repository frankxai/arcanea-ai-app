{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__arcanea-mcp__*",
      "mcp__arcanea-memory__*",
      "mcp__starlight-sis__*",
      "mcp__supabase__*",
      "mcp__comfyui__*",
      "mcp__claude_ai_Vercel__*",
      "mcp__claude_ai_Linear__*",
      "mcp__claude_ai_Slack__*",
      "mcp__claude_ai_Canva__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__notion__*",
      "mcp__linear-server__*",
      "mcp__claude_ai_Excalidraw__*",
      "mcp__claude_ai_Miro__*"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "next-devtools",
    "github",
    "supabase",
    "arcanea-mcp",
    "arcanea-memory",
    "figma-remote-mcp",
    "notion",
    "linear-server",
    "playwright"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/Arcanea/.claude/hooks/session-start.sh\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Write|Edit)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/Arcanea/.claude/hooks/voice-check.sh\" \"$TOOL_INPUT\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/Arcanea/.claude/hooks/session-end.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/Arcanea/.claude/statusline.mjs\""
  }
}
