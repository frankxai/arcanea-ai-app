{
  "version": "2026-02-27",
  "purpose": "Shared MCP server registry for Claude/OpenCode/Codex alignment",
  "servers": {
    "next-devtools": {
      "enabled": true,
      "type": "command",
      "command": "npx",
      "args": ["-y", "next-devtools-mcp@latest"],
      "value": "Next.js runtime diagnostics, route tools, error introspection"
    },
    "github": {
      "enabled": true,
      "type": "command",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "value": "PR/issue/repo automation"
    },
    "playwright": {
      "enabled": true,
      "type": "command",
      "command": "npx",
      "args": ["-y", "@executeautomation/playwright-mcp-server"],
      "value": "Browser validation and UX testing"
    },
    "supabase": {
      "enabled": true,
      "type": "http",
      "url": "https://mcp.supabase.com/mcp",
      "value": "DB/schema/admin workflows"
    },
    "arcanea-mcp": {
      "enabled": true,
      "type": "command",
      "command": "node",
      "args": ["/mnt/c/Users/frank/Arcanea/packages/arcanea-mcp/dist/cli.js"],
      "buildRequired": true,
      "buildCommand": "pnpm -C /mnt/c/Users/frank/Arcanea/packages/arcanea-mcp build",
      "value": "Arcanea-native worldbuilding and orchestration tools"
    },
    "arcanea-memory": {
      "enabled": true,
      "type": "command",
      "command": "node",
      "args": ["/mnt/c/Users/frank/Arcanea/packages/memory-mcp/dist/server.js"],
      "env": {
        "STARLIGHT_PATH": "/mnt/c/Users/frank/Arcanea/.arcanea/memory"
      },
      "buildRequired": true,
      "buildCommand": "pnpm -C /mnt/c/Users/frank/Arcanea/packages/memory-mcp build",
      "value": "Persistent memory layer across agents"
    },
    "figma-remote-mcp": {
      "enabled": false,
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "value": "Design extraction and token alignment"
    },
    "notion": {
      "enabled": false,
      "type": "http",
      "url": "https://mcp.notion.com/mcp",
      "value": "Product and docs synchronization"
    },
    "linear-server": {
      "enabled": false,
      "type": "sse",
      "url": "https://mcp.linear.app/sse",
      "value": "Issue planning and delivery tracking"
    }
