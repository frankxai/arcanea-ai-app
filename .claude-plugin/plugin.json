  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "arcanea",
    "claude-code",
    "mythology",
    "world-building",
    "prompt-framework",
    "design-system",
    "ai-creation",
    "luminors",
    "guardians",
    "starlight-vault"
  ],
  "commands": [
    ".claude/commands/"
  ],
  "skills": [
    ".claude/skills/"
  ],
  "agents": [
    "agents/agent-implementer",
    "agents/arcanea-architect"
  ],
  "rules": [
    "rules/"
  ],
  "features": {
