{
  "name": "starlight-vault",
  "version": "1.0.0",
  "description": "Arcanea's continuous learning system — captures creative patterns as Starlight Fragments",
  "storage": {
    "root": ".arcanea/starlight-vault",
    "observations": "observations.jsonl",
    "fragments": "fragments/",
    "constellations": "constellations/"
  },
  "observer": {
    "enabled": true,
    "interval_minutes": 15,
    "max_observations_mb": 10,
    "archive_days": 30,
    "active_hours": {
      "start": 8,
      "end": 23
    }
  },
  "confidence": {
    "initial_1_2": 0.3,
    "initial_3_5": 0.5,
    "initial_6_10": 0.7,
    "initial_11_plus": 0.85,
    "confirm_boost": 0.05,
    "contradict_penalty": 0.1,
    "weekly_decay": 0.02,
    "promotion_threshold": 0.8,
    "promotion_min_projects": 2
  },
  "domains": [
    "code-style",
    "architecture",
    "testing",
    "design-system",
    "lore-consistency",
    "ai-prompting",
    "world-building",
    "content-voice"
  ],
  "secret_patterns": [
    "sk-[a-zA-Z0-9]+",
    "sbp_[a-zA-Z0-9]+",
    "sb_secret_[a-zA-Z0-9]+",
    "ghp_[a-zA-Z0-9]+",
    "eyJ[a-zA-Z0-9]+"
  ]
}
