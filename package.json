{
  "name": "arcanea",
  "version": "1.0.0",
  "description": "AI-powered creative ecosystem empowering the next generation of creators",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:academy": "turbo run dev --filter=@arcanea/academy",
    "dev:web": "turbo run dev --filter=@arcanea/web",
    "dev:chat": "turbo run dev --filter=@arcanea/chat",
    "dev:studio": "turbo run dev --filter=@arcanea/studio",
    "dev:gallery": "turbo run dev --filter=@arcanea/gallery",
    "dev:library": "turbo run dev --filter=@arcanea/library",
    "dev:realms": "turbo run dev --filter=@arcanea/realms",
    "dev:sanctuary": "turbo run dev --filter=@arcanea/sanctuary",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:all": "node --test packages/*/tests/*.test.mjs",
    "test:quick": "node --test packages/extension-core/tests/*.test.mjs packages/auth/tests/*.test.mjs packages/core/tests/*.test.mjs packages/arcanea-mcp/tests/*.test.mjs",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "supabase:project-graph:plan": "tsx scripts/project-graph-activate.ts --plan",
    "supabase:project-graph:apply": "tsx scripts/project-graph-activate.ts --apply",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,md,json}\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=!@arcanea/mobile && changeset publish",
    "ops:health": "node scripts/ops-health-check.js --quick",
    "ops:health:deep": "node scripts/ops-health-check.js --quick --deep",
    "ops:release-gate": "node scripts/ops-health-check.js --quick --deep --json",
    "ops:machine": "node scripts/machine-readiness-check.js",
    "ops:machine:json": "node scripts/machine-readiness-check.js --json",
    "verify:project-workspaces": "tsx scripts/verify-project-workspaces.ts",
    "embed:library": "cd apps/web && npx tsx ../../scripts/embed-library.ts",
    "embed:library:dry-run": "cd apps/web && npx tsx ../../scripts/embed-library.ts --dry-run --verbose",
    "sis:sync": "node scripts/sis-context-bridge.mjs",
    "sis:mcp": "node scripts/sis-mcp-server.mjs",
    "sis:append": "node scripts/sis-write.mjs",
    "sis:contracts": "node scripts/sis-contract-check.mjs",
    "sis:schema-check": "node scripts/sis-schema-check.mjs",
    "sis:legacy-export": "node scripts/sis-legacy-export.mjs",
    "sis:check": "node scripts/sis-context-bridge.mjs && node scripts/sis-check.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.76.1",
    "next": "^16.1.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@tailwindcss/typography": "^0.5.13",
    "@turbo/gen": "^2.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.2",
    "postcss": "^8.4.38",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.9",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.7.0",
    "turbo": "^2.7.3",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": "20.x",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "keywords": [
    "ai",
    "creativity",
    "education",
    "community",
    "creators",
    "artificial-intelligence",
    "creative-tools",
    "learning-platform",
    "next-js",
    "react-native",
    "typescript"
  ],
  "author": {
    "name": "Frank Riemer",
    "email": "frank@arcanea.ai",
    "url": "https://github.com/frankxai"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/frankxai/arcanea.git"
  },
  "bugs": {
    "url": "https://github.com/frankxai/arcanea/issues"
  },
  "homepage": "https://arcanea.ai",
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  }
}
